// MasterDetail.lantern
//
// Master-detail pattern with data model, list, and detail view.

struct Project {
    let name: String
    let language: String
    let stars: Int
    let description: String
}

let projects = [
    Project(name: "Lantern", language: "Swift", stars: 42,
            description: "An embeddable Swift interpreter with integrated debugging and SwiftUI bridge."),
    Project(name: "Wick", language: "Swift", stars: 12,
            description: "A development environment for Lantern scripts with live preview and debugger."),
    Project(name: "LanternKit", language: "Swift", stars: 8,
            description: "Reusable SwiftUI components for building Lantern development tools."),
    Project(name: "CodeEditorView", language: "Swift", stars: 320,
            description: "A SwiftUI code editor with syntax highlighting, line numbers, and minimap."),
    Project(name: "SwiftSyntax", language: "Swift", stars: 2800,
            description: "A library for parsing, inspecting, and transforming Swift source code.")
]

struct ProjectDetailView: View {
    let project: Project

    var body: some View {
        VStack(spacing: 16) {
            Text(project.name)
                .font("largeTitle")
                .bold()

            HStack(spacing: 12) {
                Label(project.language, systemImage: "chevron.left.forwardslash.chevron.right")
                    .foregroundStyle("blue")
                Label("\(project.stars) stars", systemImage: "star.fill")
                    .foregroundStyle("orange")
            }
            .font("subheadline")

            Text(project.description)
                .font("body")
                .foregroundStyle("secondary")
                .padding(16)

            Spacer()
        }
        .padding(20)
    }
}

struct ProjectListView: View {
    @State var selectedIndex = 0

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                HStack {
                    Text("Projects")
                        .font("title")
                        .bold()
                    Spacer()
                    Text("\(projects.count) items")
                        .foregroundStyle("secondary")
                }
                .padding(16)

                VStack(spacing: 1) {
                    for i in 0..<projects.count {
                        let p = projects[i]
                        Button(p.name) {
                            selectedIndex = i
                        }
                        .padding(12)
                    }
                }

                Divider()

                ProjectDetailView(project: projects[selectedIndex])
            }
            .navigationTitle("Master-Detail Demo")
        }
    }
}

// Instantiate for preview
ProjectListView()
